DOCKER_ENV=prod

# docker
DOCKER_CONTAINER_NAME_PREFIX=zabbix-hosts-relations
NODE_PORT_PUBLIC=3012
NGINX_PORT_PUBLIC=3013

# nginx basic auth (BASIC_AUTH_ENABLE=1 to require login, 0 to disable)
BASIC_AUTH_ENABLE=0
BASIC_AUTH_LOGIN=admin
BASIC_AUTH_PASSWORD=changeme

# zabbix
ZABBIX_API_TOKEN=your-zabbix-api-token
ZABBIX_URL=http://localhost
# Limit the host list to these Zabbix host groups (exact names, separated by
# "|"). Leave empty to show all hosts. Example: ZABBIX_GROUPS=Linux servers|Routers
ZABBIX_GROUPS=

# data server
DATA_URL=http://localhost:3013

# ssh login used by the "SSH" button on the host detail page
SSH_LOGIN=login

# redis (used by the python server to store ansible run status)
REDIS_HOST=redis
REDIS_PORT=6379

# ansible: the python server runs ANSIBLE_SCRIPT <target> over ssh on this host.
# ANSIBLE_MOCK=1 skips the real ssh and returns a canned playbook run instead.
ANSIBLE_MOCK=1
ANSIBLE_SSH_HOST=ansible.example.com
ANSIBLE_SSH_LOGIN=login
ANSIBLE_SSH_PASSWORD=
ANSIBLE_SCRIPT=/ansible_quickstart/run.sh
